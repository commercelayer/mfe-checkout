{
  "name": "mfe-checkout",
  "version": "6.5.1",
  "engines": {
    "node": ">=20.x"
  },
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "start": "next start -p $PORT",
    "check": "pnpm biome check components pages",
    "check:fix": "pnpm biome check components pages --write",
    "test": "playwright test",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:ui": "NEXT_PUBLIC_BASE_PATH=http://localhost:3000 playwright test --ui",
    "serve": "serve -l tcp://localhost:$PORT/ -n -s out/dist",
    "clean": "pnpm dlx rimraf --glob **/node_modules **/pnpm-lock.yaml",
    "dep:major": "pnpm dlx npm-check-updates --packageFile '**/package.json' -u",
    "dep:minor": "pnpm dlx npm-check-updates -t semver --packageFile '**/package.json' -u",
    "browserslist:update": "pnpm dlx update-browserslist-db@latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/commercelayer/mfe-checkout.git"
  },
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      "next",
      "next-major",
      {
        "name": "beta",
        "prerelease": true
      },
      {
        "name": "alpha",
        "prerelease": true
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/git",
      [
        "@semantic-release/github",
        {
          "addReleases": "top"
        }
      ]
    ]
  },
  "author": {
    "name": "Matteo Alessani",
    "email": "matteo@commercelayer.io"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/commercelayer/mfe-checkout/issues"
  },
  "homepage": "https://github.com/commercelayer/mfe-checkout#readme",
  "keywords": [
    "reactjs",
    "nextjs",
    "jamstack",
    "headless",
    "ecommerce",
    "api",
    "checkout",
    "commercelayer"
  ],
  "dependencies": {
    "@adyen/adyen-web": "6.28.0",
    "@commercelayer/js-auth": "^7.3.0",
    "@commercelayer/organization-config": "^2.8.0",
    "@commercelayer/react-components": "4.29.7-beta.5",
    "@commercelayer/sdk": "^6.56.0",
    "@faker-js/faker": "^10.4.0",
    "@headlessui/react": "^2.2.10",
    "@newrelic/browser-agent": "^1.312.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/async-retry": "1.4.8",
    "@types/node": "^24.12.2",
    "@types/react": "^18.3.28",
    "@types/react-gtm-module": "^2.0.4",
    "async-retry": "^1.3.3",
    "classnames": "^2.5.1",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "dotenv": "^17.4.1",
    "i18next": "^25.10.10",
    "next": "^16.2.2",
    "next-build-id": "^3.0.0",
    "next-i18next": "^15.4.3",
    "postcss": "^8.5.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-gtm-module": "^2.0.11",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^6.30.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@next/bundle-analyzer": "^16.2.2",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "baseline-browser-mapping": "^2.10.16",
    "npm-check-updates": "^19.6.6",
    "semantic-release": "^25.0.3",
    "serve": "^14.2.6"
  },
  "cacheDirectories": [
    ".next/cache"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@tailwindcss/oxide",
      "core-js",
      "iframe-resizer",
      "sharp"
    ]
  }
}
